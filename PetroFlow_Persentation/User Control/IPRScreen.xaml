<UserControl x:Class="PetroFlow_Persentation.User_Control.IPRScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetroFlow_Persentation.User_Control"
             mc:Ignorable="d" 
             d:DesignHeight="637.583" d:DesignWidth="1035.876">
    <Grid Margin="0">

        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Top Left -->
        <Border Name="ReservoirDataBorder"
                Grid.Row="0" 
                Grid.Column="0" 
                Style="{DynamicResource CardStyle}"
                Margin="0,0,10,10">
            <Grid Name="ReservoirDataMainGrid">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Name="ReservoirDataTitle"
                           Text="Reservoir Data"
                           FontSize="20"
                           FontWeight="Black"
                           Foreground="{StaticResource Brush.Accent}"
                           Height="Auto"/>

                <!-- Separator -->
                <Border Grid.Row="1" Style="{StaticResource Separator}"/>

                <!-- Content -->
                <TabControl Name="ReservoirDataTabContorl"
                            Grid.Row="2">
                    <TabItem Name="PresentReservoirDataTab"
                                 Header="Present">
                        <Grid Name="PresentReservoirDataGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Name="PresentReservoirPressureLabel"
                                    Grid.Column="0" 
                                    Grid.Row="0"
                                    Text="Reservoir Pressure:" />
                            <TextBlock Name="BubblePointPressureLabel"
                                    Grid.Column="0" 
                                    Grid.Row="1"
                                    Text="Bubble Point Pressure:"/>
                            <TextBlock Name="PresentOilRelativePremeabilityLabel"
                                    Grid.Column="0" 
                                    Grid.Row="2"
                                    Text="Oil Relative Permeability:" />
                            <TextBlock Name="PresentOilViscosityLabel"
                                    Grid.Column="0" 
                                    Grid.Row="3"
                                    Text="Oil Viscosity:" />
                            <TextBlock Name="PresentOilFormationVolumeFactorLabel"
                                    Grid.Column="0" 
                                    Grid.Row="4"
                                    Text="Oil Formation Volume Factor:" />

                            <TextBox Name="PresentReservoirPressureInput"
                                    Grid.Column="1"
                                    Grid.Row="0"
                                    Margin="20,10,20,10"/>
                            <TextBox Name="BubblePoitPressureInput"
                                    Grid.Column="1" 
                                    Grid.Row="1" 
                                    Margin="20,10,20,10"/>
                            <TextBox Name="PresentOilRelativePermeabilityInput"
                                    Grid.Column="1" 
                                    Grid.Row="2" 
                                    Margin="20,10,20,10"/>
                            <TextBox Name="PresentOilViscosityInput"
                                    Grid.Column="1" 
                                    Grid.Row="3" 
                                    Margin="20,10,20,10"/>
                            <TextBox Name="PresnetOilFormationVolumeFactorInput"
                                    Grid.Column="1" 
                                    Grid.Row="4" 
                                    Margin="20,10,20,10"/>

                            <ComboBox Name="PresentReservoiPressureUnit" 
                                          Grid.Column="2" 
                                          Grid.Row="0" 
                                          Margin="20,10,20,10"/>
                            <ComboBox Name="BubblePointPressureUnit"
                                    Grid.Column="2" 
                                    Grid.Row="1" 
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="PresentOilFormationVolumeFactorUnit"
                                    Grid.Column="2" 
                                    Grid.Row="2" 
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="PresentOilViscosityUnit"
                                    Grid.Column="2" 
                                    Grid.Row="3" 
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="PresnetOilFormationVolumeFactorUnit"
                                    Grid.Column="2" 
                                    Grid.Row="4" 
                                    Margin="20,10,20,10"/>
                        </Grid>
                    </TabItem>
                    <TabItem Name="FutureReservoirDataTab"
                                 Header="Future">
                        <Grid Name="FutureReservoirDataGrid">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Name="FutureReservoirPressureLabel"
                                    Grid.Column="0" 
                                    Grid.Row="0"
                                    Text="Reservoir Pressure:" />
                            <TextBlock Name="FutureOilRelativePermeabilityLabel"
                                    Grid.Column="0" 
                                    Grid.Row="1"
                                    Text="Oil Relative Permeability:" />
                            <TextBlock Name="FutureOilViscosityLabel"
                                    Grid.Column="0" 
                                    Grid.Row="2"
                                    Text="Oil Viscosity:" />
                            <TextBlock Name="FutureOilFormationVolumeFactorLabel"
                                    Grid.Column="0" 
                                    Grid.Row="3"
                                    Text="Oil Formation Volume Factor:" />

                            <TextBox Name="FutureReservoirPressureInput"
                                    Grid.Column="1" 
                                    Grid.Row="0"
                                    Margin="20,10,20,10"/>
                            <TextBox Name="FutureOilRelativePermeabilityInput"
                                    Grid.Column="1" 
                                    Grid.Row="1" 
                                    Margin="20,10,20,10"/>
                            <TextBox Name="FutureOilViscosityInput"
                                    Grid.Column="1" 
                                    Grid.Row="2"
                                    Margin="20,10,20,10"/>
                            <TextBox Name="FutureOilFormationVolumeFactorInput"
                                    Grid.Column="1" 
                                    Grid.Row="3"
                                    Margin="20,10,20,10"/>

                            <ComboBox Name="FutureReservoirPressureUnit"
                                    Grid.Column="2" 
                                    Grid.Row="0"
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="FutureOilRelativePermeabilityUnit"
                                    Grid.Column="2" 
                                    Grid.Row="1"
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="FutureOilViscosityUnit"
                                    Grid.Column="2" 
                                    Grid.Row="2"
                                    Margin="20,10,20,10"/>
                            <ComboBox Name="FutureOilFormationVolumeFactorUnit"
                                    Grid.Column="2" 
                                    Grid.Row="3"
                                    Margin="20,10,20,10"/>

                        </Grid>
                    </TabItem>
                </TabControl>

            </Grid>
        </Border>

        <!-- Top Right -->
        <Border Name="GeneralControlBorder"
                Grid.Row="0" 
                Grid.Column="1" 
                Style="{DynamicResource CardStyle}"
                Margin="10,0,0,10">
            <Grid Name="GeneralControlGrid">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Name="GeneralControlTitle"
                           Text="General IPR Control"
                           FontSize="20"
                           FontWeight="Black"
                           Foreground="{StaticResource Brush.Accent}"/>

                <!-- Divider -->
                <Border Grid.Row="1" Style="{StaticResource Separator}"/>

                <!-- Content -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Name="WellTypeBorder"
                            Grid.Row="0"
                            Style="{StaticResource CardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Name="ReseroirTypeLabel"
                                       Text="Reservoir Type:" 
                                       Foreground="{StaticResource Brush.Accent}" 
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Height="Auto"
                                       Width="145"/>

                            <RadioButton Name="ReserrvoirTypeOil"
                                         Content="Oil" 
                                         IsChecked="True" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>

                            <RadioButton Name="ReservoirTypeGas"
                                         Content="Gas" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>
                        </StackPanel>

                    </Border>

                    <Border Name="IPRScenarioBorder"
                            Grid.Row="1"
                            Style="{StaticResource CardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Name="IPRScenarioLabel"
                                       Text="IPR Scenario:" 
                                       Foreground="{StaticResource Brush.Accent}" 
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Height="Auto"
                                       Width="145"/>

                            <RadioButton Name="IPRScenarioPresent"
                                         Content="Present" 
                                         IsChecked="True" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>

                            <RadioButton Name="IPRScenarioFuture"
                                         Content="Future" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>
                        </StackPanel>

                    </Border>

                    <Border Name="IPRMethodSelectionBorder"
                            Grid.Row="2"
                            Style="{StaticResource CardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Name="IPRMEthhodSelectionTitle"
                                       Text="IPR Method:" 
                                       Foreground="{StaticResource Brush.Accent}" 
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Height="30"
                                       Width="145"/>

                            <RadioButton Name="IPRMethodSelectedVogel"
                                         Content="Vogel" 
                                         IsChecked="True"  
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>

                            <RadioButton Name="IPRMethodSelectedStanding"
                                         Content="Standing" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>

                            <RadioButton Name="IPRMethodSelectedFetkovich"
                                         Content="Fetkovich" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="135"/>

                            <RadioButton Name="IPRMethodSelectedJones"
                                         Content="Jones, Blount and Glaze" 
                                         VerticalAlignment="Center"
                                         Height="Auto"
                                         Width="Auto"/>
                        </StackPanel>

                    </Border>

                </Grid>

            </Grid>
        </Border>

        <!-- Bottom -->
        <Border Name="TestDataBored"
                Grid.Row="1" 
                Grid.Column="0" 
                Grid.ColumnSpan="2" 
                Style="{DynamicResource CardStyle}"
                Margin="0,10,0,0">
            <Grid Name="TestDataGrid">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Name="TestDataTitle"
                    Text="Test Data"
                    FontSize="20"
                    FontWeight="Black"
                    Foreground="{StaticResource Brush.Accent}"/>

                <!-- Divider -->
                <Border Grid.Row="1" Style="{StaticResource Separator}"/>

                <!-- Content -->
                <Grid Grid.Row="2">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.6*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="0.4*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.2*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.15*"/>
                                <RowDefinition Height="0.15*"/>
                                <RowDefinition Height="0.7*"/>
                            </Grid.RowDefinitions>

                            <DataGrid Name="TestDataInput"
                                      Grid.Column="0"
                                      Grid.Row="0"
                                      Grid.RowSpan="3"
                                      Margin="15,5,15,15" 
                                      ScrollViewer.CanContentScroll="True" 
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Flow Rate (STB/D)" Width="*"/>
                                    <DataGridTextColumn Header="Bottom Hole Pressure (psi)"  Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Name="AddNewTestDataRowButton"
                                Grid.Column="1" 
                                Grid.Row="0"
                                Margin="25,10,25,5">
                                <Image Source="/Icons/plus.png" Margin="10"/>
                            </Button>

                            <CheckBox Name="UseTestDataCheckBox"
                                      Grid.Column="1" Grid.Row="1"
                                      Content="Use Test Data"
                                      Margin="25,5,5,5"/>

                        </Grid>

                        <Border Grid.Column="1"
                                Opacity="0.5"
                                Margin="4"
                                Background="{StaticResource Brush.Border}"/>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>


                            <TextBlock Name="TestFlowEfficiencyLabel"
                                       Grid.Column="0" 
                                       Grid.Row="0"
                                       Text="Test Flow Efficiency:"/>
                            <TextBlock Name="NewFlowEfficiencyLabel"
                                       Grid.Column="0" 
                                       Grid.Row="1"
                                       Text="New Flow Efficiency:"/>
                            <TextBlock Name="WellExponentLabel"
                                       Grid.Column="0" 
                                       Grid.Row="3"
                                       Text="Well Exponent:"/>
                            <TextBlock Name="FlowCoefficientLabel"
                                       Grid.Column="0" 
                                       Grid.Row="4"
                                       Text="Flow coefficient:"/>

                            <TextBox Name="TestFlowEfficiecyInput"
                                     Grid.Column="1" 
                                     Grid.Row="0"
                                     Margin="20,5,20,5"/>
                            <TextBox Name="NewFlowEfficiencyInput"
                                     Grid.Column="1" 
                                     Grid.Row="1"
                                     Margin="20,5,20,5"/>
                            <TextBox Name="WellExponentInput"
                                     Grid.Column="1" 
                                     Grid.Row="3"
                                     Margin="20,5,20,5"/>
                            <TextBox Name="FlowCoefficientInput"
                                     Grid.Column="1" 
                                     Grid.Row="4"
                                     Margin="20,5,20,5"/>

                            <ComboBox Name="TestFlowEfficiencyUnit"
                                      Grid.Column="2" 
                                      Grid.Row="0"
                                      Margin="20,5,20,5"/>
                            <ComboBox Name="NewFlowEfficincyUnit"
                                      Grid.Column="2" 
                                      Grid.Row="1"
                                      Margin="20,5,20,5"/>
                            <ComboBox Name="WellWxponwntUnit"
                                      Grid.Column="2" 
                                      Grid.Row="3"
                                      Margin="20,5,20,5"/>
                            <ComboBox Name="FlowCoefficintUnit"
                                      Grid.Column="2" 
                                      Grid.Row="4"
                                      Margin="20,5,20,5"/>

                        </Grid>

                    </Grid>
                </Grid>

            </Grid>
        </Border>


    </Grid>
</UserControl>
