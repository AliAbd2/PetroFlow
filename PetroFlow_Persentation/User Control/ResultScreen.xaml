<UserControl x:Class="PetroFlow_Persentation.User_Control.ResultScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetroFlow_Persentation.User_Control"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="1400.883" d:DesignWidth="3090.324">
    <Grid Name="MainResultGrid"
        Background="{StaticResource Brush.Background}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition Width="0.6*"/>
        </Grid.ColumnDefinitions>

        <Border Name="PlotCard"
                Grid.Column="1"
                Margin="10,0,0,0"
                Style="{StaticResource CardStyle}">

            <scottplot:WpfPlot Name="ResultPlot"/>

        </Border>

        <Grid Name="DataResultGrid"
              Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="0.2*"/>
                <RowDefinition Height="0.6*"/>
                <RowDefinition Height="0.2*"/>
            </Grid.RowDefinitions>

            <Border Name="OperatingPointCard"
                    Grid.Row="0"
                    Margin="0,0,10,10"
                    Style="{StaticResource CardStyle}">

                <Grid Name="OperatingPointGrid">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="OperatingPointTitle"
                               Grid.Row="0"
                               Style="{StaticResource TitleLabel}"
                               Text="Operating Point"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource Separator}"/>

                    <Grid Grid.Row="2">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Name="OperatingPressureStackPanel"
                                    Grid.Row="0"
                                    Orientation="Horizontal">

                            <TextBlock Name="OperatingPressureLabel"
                                       Text="Operating Pressure:"
                                       Width="150"/>

                            <TextBlock Name="OperatingPressureValue"
                                       Text="Unknown"
                                       Width="100"/>

                            <TextBlock Name="OperatingPressureUnit"
                                       Text="psi"
                                       Width="Auto"/>

                        </StackPanel>

                        <StackPanel Name="OperatingFlowRateStackPanel"
                                    Grid.Row="1"
                                    Orientation="Horizontal">

                            <TextBlock Name="OperatingFlowRateLabel"
                                       Text="Operating Flow Rate:"
                                       Width="150"/>

                            <TextBlock Name="OperatingFlowRateValue"
                                       Text="Unknown"
                                       Width="100"/>

                            <TextBlock Name="OperatingFlowRateUnit"
                                       Text="STB/day"
                                       Width="Auto"/>

                        </StackPanel>

                    </Grid>

                </Grid>

            </Border>

            <Border Name="ResultDataCard"
                    Grid.Row="1"
                    Margin="0,10,10,10"
                    Style="{StaticResource CardStyle}">

                <Grid Name="ResultDataGrid">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="ResultDataTitle"
                               Grid.Row="0"
                               Text="Result Data"
                               Style="{StaticResource TitleLabel}"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource Separator}"/>

                    <DataGrid Name="ResultDataDataGrid"
                              Grid.Column="0"
                              Grid.Row="2"
                              Margin="15,5,15,15" 
                              ScrollViewer.CanContentScroll="True" 
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Flow Rate (STB/day)" 
                                                Width="Auto"
                                                Binding="{Binding FlowRate}"/>
                            <DataGridTextColumn Header="IPR Bottom hole Pressure (psi)"  
                                                Width="Auto"
                                                Binding="{Binding IPRBottomHolePressure}"/>
                            <DataGridTextColumn Header="VLP Bottom hole Pressure (psi)"  
                                                Width="*"
                                                Binding="{Binding VLPBottomHolePressure}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>

            </Border>

            <Border Name="MainControlBorder"
                    Grid.Row="2"
                    Margin="0,10,10,0"
                    Style="{StaticResource CardStyle}">

                <Grid Name="MainControlGrid">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Button Name="GenerateIPRButton"
                            Grid.Column="0"
                            Grid.Row="0"
                            Content="Generate IPR"
                            Margin="10"
                            Width="180"
                            Height="50"
                            Click="GenerateIPR"/>

                    <Button Name="GeneratVLPButton"
                            Grid.Column="1"
                            Grid.Row="0"
                            Content="Generate VLP"
                            Margin="10"
                            Width="180"
                            Height="50"
                            Click="GenerateVLP"/>

                    <Button Name="GetOperatingPointButton"
                            Grid.Column="2"
                            Grid.Row="0"
                            Content="Find Operating Point"
                            Margin="10"
                            Width="180"
                            Height="50"
                            Click="GetOperatingPoint"/>

                    <Button Name="ResetMenuButton"
                            Grid.Column="0"
                            Grid.Row="1"
                            Content="Reset Menu"
                            Margin="10"
                            Width="180"
                            Height="50"
                            Click="ResetMenu"/>

                    <Button Name="ClearPlotButton"
                            Grid.Column="2"
                            Grid.Row="1"
                            Content="Clear Plot"
                            Margin="10"
                            Width="180"
                            Height="50"
                            Click="ClearPlot"/>

                </Grid>

            </Border>

        </Grid>


    </Grid>
</UserControl>
